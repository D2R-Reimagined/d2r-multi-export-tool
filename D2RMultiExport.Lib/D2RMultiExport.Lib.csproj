<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>D2RMultiExport.Lib</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="D2RReimaginedTools.FileExtensions" Version="0.5.4" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Config\stat-overrides.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Config\export-config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Config\synthetic-strings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Config\class-ranges.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <!--
      Bundled CASC-derived data. This folder ships only the canonical
      runes.txt used by the runeword importer to flag vanilla runewords.
      Users who hit missing-translation reports should extract the relevant
      data\local\lng\strings\*.json files themselves with CascView and
      point the export at that folder via the base-strings option;
      the bundled tree intentionally no longer ships Blizzard string tables.
    -->
    <None Update="Config\CASC_DATA\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
